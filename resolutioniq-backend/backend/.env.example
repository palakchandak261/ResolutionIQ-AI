# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/resolutioniq?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_too
JWT_REFRESH_EXPIRES_IN=30d

# AI - Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# AI - Whisper (OpenAI compatible STT endpoint)
WHISPER_API_KEY=your_openai_or_whisper_api_key
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions

# Geo / duplicate detection
DUPLICATE_RADIUS_METERS=100
CORRELATION_RADIUS_METERS=50

# File uploads
MAX_UPLOAD_MB=15
